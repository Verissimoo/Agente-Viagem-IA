# ──────────────────────────────────────────────────────────────────
# .env.example — copie para .env e preencha com suas credenciais
# ──────────────────────────────────────────────────────────────────
# No Railway: copiar cada par KEY=VALUE para Variables na UI do projeto.
# NÃO commite o arquivo .env real (está no .gitignore).

# ── Kayak (via RapidAPI) ─────────────────────────────────────────
RAPIDAPI_KEY=
RAPIDAPI_HOST=kayak-api.p.rapidapi.com
KAYAK_BASE_URL=https://kayak-api.p.rapidapi.com
API_RPS=1.0
RAPIDAPI_MAX_ATTEMPTS=6
RAPIDAPI_TIMEOUT=90
PARSER_DEBUG=0
KAYAK_POLL_ENABLED=1
KAYAK_POLL_MAX=10
KAYAK_POLL_SLEEP=1.5
KAYAK_MAX_PAGES=2

# ── Câmbio (FX) ──────────────────────────────────────────────────
TARGET_CURRENCY=BRL
FX_BASE_URL=https://api.frankfurter.app
FX_TTL_SECONDS=21600
FX_TIMEOUT=20

# ── BuscaMilhas (provedor padrão) ────────────────────────────────
BUSCAMILHAS_CHAVE=
BUSCAMILHAS_SENHA=
BUSCAMILHAS_CONNECT_TIMEOUT=10
BUSCAMILHAS_READ_TIMEOUT=60
BUSCAMILHAS_MAX_ATTEMPTS=3
# Rate limit (req/s). 0 = sem limite
BUSCAMILHAS_RPS=0
MILES_MAX_CALLS=20

# ── Economilhas (provedor alternativo de milhas) ─────────────────
# Selecionável no popover ⚙️ do Streamlit.
ECONOMILHAS_API_KEY=
ECONOMILHAS_ENDPOINT=https://api.economilha.com/flights/search
ECONOMILHAS_QUOTA_ENDPOINT=https://api.economilha.com/quota
ECONOMILHAS_CONNECT_TIMEOUT=10
ECONOMILHAS_READ_TIMEOUT=90
ECONOMILHAS_MAX_ATTEMPTS=3

# ── MCP (Award Search) ───────────────────────────────────────────
MCP_BEARER_TOKEN=

# ── LLM (Groq — usado pelo intent parser) ────────────────────────
# NÃO confundir com "Grok" (xAI). O projeto usa Groq Cloud
# via litellm. Obter chave em https://console.groq.com.
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile

# ── Configuração de ranking / negócio ────────────────────────────
PCD_OFFLINE=0
COST_PER_MILE_BRL=0.015
CONNECTION_PENALTY_BRL=80.0
MILES_MAX_CODES_PER_PLACE=1
