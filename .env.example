# ──────────────────────────────────────────────────────────────────
# .env.example — copie para .env e preencha com suas credenciais
# ──────────────────────────────────────────────────────────────────

# ── Kayak (via RapidAPI) ─────────────────────────────────────────
RAPIDAPI_KEY=
RAPIDAPI_HOST=
KAYAK_BASE_URL=
API_RPS=
RAPIDAPI_MAX_ATTEMPTS=3
RAPIDAPI_TIMEOUT=30
PARSER_DEBUG=0
KAYAK_POLL_ENABLED=1
KAYAK_POLL_MAX=8
KAYAK_POLL_SLEEP=2
KAYAK_MAX_PAGES=3

# ── Câmbio (FX) ──────────────────────────────────────────────────
TARGET_CURRENCY=BRL
FX_BASE_URL=
FX_TTL_SECONDS=3600
FX_TIMEOUT=10

# ── BuscaMilhas (provedor padrão) ────────────────────────────────
BUSCAMILHAS_CHAVE=
BUSCAMILHAS_SENHA=
BUSCAMILHAS_CONNECT_TIMEOUT=10
BUSCAMILHAS_READ_TIMEOUT=60
BUSCAMILHAS_MAX_ATTEMPTS=3
# Rate limit (req/s). 0 = sem limite
BUSCAMILHAS_RPS=0

# ── Economilhas (provedor alternativo de milhas) ─────────────────
# Selecionável no popover ⚙️ do Streamlit. Cobre múltiplos programas
# em uma única chamada (SMILES, LATAM, AZUL, AZUL_INTERLINE, COPA,
# IBERIA, BRITISH).
ECONOMILHAS_API_KEY=sua-chave-aqui
ECONOMILHAS_ENDPOINT=https://api.economilha.com/flights/search
ECONOMILHAS_QUOTA_ENDPOINT=https://api.economilha.com/quota
ECONOMILHAS_CONNECT_TIMEOUT=10
ECONOMILHAS_READ_TIMEOUT=90
ECONOMILHAS_MAX_ATTEMPTS=3
