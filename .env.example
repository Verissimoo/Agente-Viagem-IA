# ──────────────────────────────────────────────────────────────────
# .env.example — copie para .env e preencha com suas credenciais
# ──────────────────────────────────────────────────────────────────
# No Railway: copiar cada par KEY=VALUE para Variables na UI do projeto.
# NÃO commite o arquivo .env real (está no .gitignore).

# ── Kayak (via RapidAPI) ─────────────────────────────────────────
RAPIDAPI_KEY=
RAPIDAPI_HOST=kayak-api.p.rapidapi.com
KAYAK_BASE_URL=https://kayak-api.p.rapidapi.com
API_RPS=1.0
RAPIDAPI_MAX_ATTEMPTS=6
RAPIDAPI_TIMEOUT=90
PARSER_DEBUG=0
KAYAK_POLL_ENABLED=1
KAYAK_POLL_MAX=10
KAYAK_POLL_SLEEP=1.5
KAYAK_MAX_PAGES=2

# ── Câmbio (FX) ──────────────────────────────────────────────────
TARGET_CURRENCY=BRL
FX_BASE_URL=https://api.frankfurter.app
FX_TTL_SECONDS=21600
FX_TIMEOUT=20

# ── BuscaMilhas (provedor padrão) ────────────────────────────────
BUSCAMILHAS_CHAVE=
BUSCAMILHAS_SENHA=
BUSCAMILHAS_CONNECT_TIMEOUT=10
BUSCAMILHAS_READ_TIMEOUT=60
BUSCAMILHAS_MAX_ATTEMPTS=3
# Rate limit (req/s). 0 = sem limite
BUSCAMILHAS_RPS=0
MILES_MAX_CALLS=20

# ── Economilhas (provedor alternativo de milhas) ─────────────────
# 0 = desliga (não tenta puxar; útil quando a conta está sem créditos/HTTP 402).
ECONOMILHAS_ENABLED=1
ECONOMILHAS_API_KEY=
ECONOMILHAS_ENDPOINT=https://api.economilha.com/flights/search
ECONOMILHAS_QUOTA_ENDPOINT=https://api.economilha.com/quota
ECONOMILHAS_CONNECT_TIMEOUT=10
ECONOMILHAS_READ_TIMEOUT=90
ECONOMILHAS_MAX_ATTEMPTS=3

# ── seats.aero (award internacional multi-programa) ──────────────
# Partner API com API KEY ESTÁTICA (header Partner-Authorization). O login
# por magic-link do site NÃO é usado pela API — gere a key na aba "API" das
# settings (conta Pro). Sem a key, o adapter retorna [] silenciosamente.
# Piloto: Aeroplan + Lifemiles + Flying Blue (override em SEATS_AERO_SOURCES).
SEATS_AERO_ENABLED=1
SEATS_AERO_API_KEY=
# SEATS_AERO_SOURCES=aeroplan,lifemiles,flyingblue
# SEATS_AERO_MAX_TRIPS=8          # teto de chamadas /trips por busca (quota: 1000/dia)
# SEATS_AERO_MAX_CONCURRENCY=3    # buscas simultâneas (protege quota no flex de datas)
# SEATS_AERO_CONNECT_TIMEOUT=10
# SEATS_AERO_READ_TIMEOUT=30
# SEATS_AERO_MAX_ATTEMPTS=3

# ── AwardTool (scraping da API interna — conta Pro própria) ──────
# Login via AWS Cognito (e-mail+senha) dirigido por Playwright; intercepta
# /search_result_v2 e decodifica os resultados. Cobre todos os programas pedidos.
# ToS proíbe automação → uso gentil + cache obrigatórios (risco de ban).
#
# ⚠️ RAILWAY/PROD: abre um navegador real (Playwright/chromium) por busca —
# pesado em RAM (~90s/crawl) → risco de OOM. Manter DESLIGADO (0) em prod até
# validar memória; se ligar, subir SEARCH_ADAPTER_BUDGET_S e cuidar do plano.
AWARDTOOL_ENABLED=0
AWARDTOOL_EMAIL=
AWARDTOOL_PASSWORD=
# Tunables (todos têm default seguro — só descomente se precisar):
# AWARDTOOL_PROGRAMS=            # vazio = TODOS os programas (recomendado)
# AWARDTOOL_RANGE_DAYS=2         # janela mínima de crawl (range de 1 dia volta vazio)
# AWARDTOOL_MAX_WINDOW_DAYS=10   # teto da janela por crawl (flex grande não vira crawl eterno)
# AWARDTOOL_BUDGET_S=80          # tempo máx. do crawl
# AWARDTOOL_MAX_CONCURRENCY=1    # 1 sessão (protege a conta de ban)
# AWARDTOOL_HEADFUL=0            # 1 = navegador visível (debug local)
# AWARDTOOL_HEALTHCHECK_BUDGET_S=90  # orçamento extra do health-check quando AwardTool entra
# AWARDTOOL_STATE_PATH=debug/awardtool_state.json  # sessão Cognito persistida (FS efêmero no Railway → relogin automático)

# ── Orçamento da fase de busca (subir se ligar AwardTool em prod) ──
# SEARCH_ADAPTER_BUDGET_S=30     # default 30; com AwardTool ligado, ~90

# ── MCP (Award Search) ───────────────────────────────────────────
MCP_BEARER_TOKEN=

# ── Skiplagged (fonte complementar: hidden-city + split cash) ────
# Não exige chave paga. Feature flag para desligar caso o site mude.
SKIPLAGGED_ENABLED=1
SKIPLAGGED_TIMEOUT=25
SKIPLAGGED_WAIT_MS=12000
# SKIPLAGGED_PARSER_DEBUG=1   # imprime contagem de ofertas/descartes

# ── Quebra de trecho INTERNACIONAL (direto + hub-split + skip-split) ──
# Orquestra 2 tipos de quebra de trecho pra rota internacional só-ida, cada
# perna validada em milhas (services/international_split.py). Faz ~6-8 scrapes
# pesados → ~2min de latência (piso de scraping externo). DESLIGADA por padrão:
# o internacional segue no fluxo run_search normal (~40-50s). Ligue p/ testar.
INTERNATIONAL_SPLIT_ENABLED=0

# ── LLM (Groq via litellm — APENAS no summarizer final) ──────────
# Groq Cloud (https://console.groq.com), não Grok (xAI).
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile
# Liga/desliga o resumo gerado por IA no endpoint /search.
ENABLE_AI_SUMMARY=0

# ── Configuração de ranking / negócio ────────────────────────────
PCD_OFFLINE=0
# Orçamento (s) da fase de adapters (internacional precisa de ~60).
SEARCH_ADAPTER_BUDGET_S=30
# Teto de navegadores Playwright simultâneos no radar (Kayak/Skiplagged). Cada
# Chromium ~250MB; em host com pouca RAM (Railway) muitos = OOM/crash-loop.
RADAR_MAX_BROWSERS=3
COST_PER_MILE_BRL=0.015
CONNECTION_PENALTY_BRL=80.0
MILES_MAX_CODES_PER_PLACE=1

# ── Chat product (produto novo, separado do gerencial) ──────────
# Desliga o produto inteiro sem afetar /search e demais endpoints.
CHAT_ENABLED=1

# ── Health-check de programas de milhas (Configurações do chat) ──
# Diagnóstico interno: testa cada programa em rotas-canário (busca real).
MILES_HEALTHCHECK_BUDGET_S=35      # orçamento de tempo total (s)
MILES_HEALTHCHECK_RATE_PER_MIN=4   # rate-limit por usuário (chamadas reais = custo)
# Override de rota-canário por programa (sem deploy). Ex.:
# MILES_CANARY_AMERICAN=GRU>JFK
# MILES_CANARY_INTERLINE=GRU>MIA

# Neon Postgres — connection string completa (sslmode=require obrigatório).
# Exemplo: postgresql://USER:PASS@HOST.sa-east-1.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Neon Auth (Stack Auth). Pega no dashboard do projeto Neon → Auth.
# MÍNIMO pro backend funcionar: NEON_AUTH_JWKS_URL (vem direto no painel).
# Os outros 3 são pro frontend (SDK do Stack Auth).
NEON_AUTH_JWKS_URL=
NEON_AUTH_PROJECT_ID=
NEON_AUTH_PUBLISHABLE_KEY=
NEON_AUTH_SECRET_KEY=

# LLM principal do chat. Anthropic Claude para qualidade no raciocínio.
ANTHROPIC_API_KEY=
CHAT_MODEL_PROVIDER=anthropic
CHAT_PRIMARY_MODEL=claude-sonnet-4-6
CHAT_CHEAP_MODEL=claude-haiku-4-5-20251001

# Limites de segurança (rate limit por usuário).
CHAT_MAX_MESSAGE_CHARS=2000
CHAT_RATE_LIMIT_PER_MIN=30
CHAT_RATE_LIMIT_SEARCH_PER_HOUR=60

# Guardrail de conteúdo (NSFW/nocivo/off-topic) — recusa antes do LLM (economia
# de token). 1 = ligado (default). 0 = desliga (jailbreak segue sempre ativo).
CHAT_CONTENT_SAFETY=1

# ── Reset de senha por e-mail (DevAuth) ──────────────────────────
# Base do link enviado no e-mail (página do frontend). Sem isso, o link sai
# relativo (/reset-password?token=...). Ex.: https://app.pcd.com/reset-password
PASSWORD_RESET_URL_BASE=
# SMTP transacional. Sem SMTP_HOST configurado, o e-mail NÃO é enviado — o link
# de reset só vai pro log do servidor (suficiente pra testar em dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=               # remetente; default = SMTP_USER
SMTP_USE_TLS=1           # STARTTLS na 587; porta 465 usa SSL automático

# Dev auth (fallback enquanto Neon Auth não está ligado).
# Em produção, deixe ambos vazios — o app exige Neon Auth.
CHAT_DEV_AUTH_SECRET=
CHAT_DEV_AUTH_FILE=debug/dev_auth.json
